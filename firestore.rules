rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() { return request.auth != null; }
    function isAdmin() { return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }

    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
      
      match /savedJobs/{jobId} {
        allow read, write: if isAuth() && request.auth.uid == uid;
      }
      
      match /portfolio/{itemId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == uid;
      }
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAuth() && (resource == null || resource.data.clientId == request.auth.uid || isAdmin());
    }

    match /applications/{appId} {
      allow read: if isAuth() && (
        resource.data.freelancerId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow write: if false; // Cloud Function only
    }

    match /conversations/{convId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow write: if isAuth() && request.auth.uid in resource.data.participants;
      
      match /messages/{msgId} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
    }
  }
}
